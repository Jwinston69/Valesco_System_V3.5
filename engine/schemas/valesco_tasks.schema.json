{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "file:/02/data/schemas/valesco_tasks.schema.json",
  "title": "Valesco Tasks — Schema v1.6",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "tasks"
  ],
  "$defs": {
    "unitToken": {
      "type": "string",
      "enum": [
        "m",
        "m2",
        "m3",
        "lm",
        "hr",
        "nr",
        "day",
        "item",
        "t",
        "l",
        "kg",
        "each"
      ]
    },
    "moneyNumber": {
      "type": "number"
    },
    "productivity": {
      "type": "object",
      "description": "Per-day outputs keyed by unit. Keys must match ^output_<unit>_day$ for whitelist units.",
      "additionalProperties": false,
      "minProperties": 1,
      "patternProperties": {
        "^output_(m|m2|m3|lm|hr|nr|day|item|t|l|kg|each)_day$": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "derivedRates": {
      "type": "object",
      "description": "Optional derived unit rates. Keys must match ^derived_unit_rate_<unit>$ for whitelist units.",
      "additionalProperties": false,
      "minProperties": 1,
      "patternProperties": {
        "^derived_unit_rate_(m|m2|m3|lm|hr|nr|day|item|t|l|kg|each)$": {
          "$ref": "#/$defs/moneyNumber"
        }
      }
    },
    "subcontractorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group",
        "id",
        "type"
      ],
      "properties": {
        "group": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "taskMaterials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "qty_per_unit",
          "unit"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "qty_per_unit": {
            "type": "number"
          },
          "unit": {
            "$ref": "#/$defs/unitToken"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "tasks_version",
        "date",
        "units"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0"
        },
        "tasks_version": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "author": {
          "type": "string"
        },
        "units": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/unitToken"
          },
          "description": "Declared unit set used by this file. All task units and dynamic keys must be from this set."
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "unit"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-\\.]+$",
            "description": "Stable task id."
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "unit": {
            "$ref": "#/$defs/unitToken"
          },
          "notes": {
            "type": "string"
          },
          "productivity": {
            "$ref": "#/$defs/productivity"
          },
          "rates": {
            "$ref": "#/$defs/derivedRates"
          },
          "materials": {
            "$ref": "#/$defs/taskMaterials"
          },
          "subcontractor": {
            "$ref": "#/$defs/subcontractorRef"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    }
  },
  "allOf": [
    {
      "description": "If productivity is present, its unit keys must be in meta.units.",
      "if": {
        "properties": {
          "meta": {
            "properties": {
              "units": {
                "minItems": 1
              }
            }
          }
        }
      },
      "then": {}
    }
  ]
}